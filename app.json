{
  "expo": {
    "name": "K-Food Travel",
    "slug": "k-food-travel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kfoodtravel",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kfoodtravel.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "맛집 사진 촬영 및 커뮤니티 업로드를 위해 카메라 권한이 필요합니다.",
        "NSPhotoLibraryUsageDescription": "저장된 음식/여행 사진을 선택하고 프로필 이미지를 설정하기 위해 사진 라이브러리 접근 권한이 필요합니다."
      }
    },
    "android": {
      "package": "com.kfoodtravel.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
