EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key-here
EXPO_PUBLIC_GOOGLE_MAPS_BASE_URL=https://www.google.com/maps/search/
EXPO_PUBLIC_SITE_URL=http://localhost:8081
EXPO_PUBLIC_ADMIN_ROUTE_ENABLED=false
EXPO_PUBLIC_USE_MOCK_AI=true

# Server-only variables.
# These must be configured only in Supabase Edge Function secrets,
# server runtime, or protected deployment settings.
# Never expose these in Expo client code.
# SUPABASE_SERVICE_ROLE_KEY=server-only-placeholder
# OPENAI_API_KEY=server-only-placeholder
# LOG_LEVEL=info
# SENTRY_AUTH_TOKEN=server-or-ci-only-placeholder
